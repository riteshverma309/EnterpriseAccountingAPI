# Copy this file to .env and configure values

# Application
APP_NAME=EnterpriseAccountingAPI
APP_VERSION=1.0.0
DEBUG=false

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://accounting_user:accounting_pass@localhost:5432/enterprise_accounting
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Test Database (used only by pytest)
TEST_DATABASE_URL=postgresql://accounting_user:accounting_pass@localhost:5432/enterprise_accounting_test

# Security
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32
